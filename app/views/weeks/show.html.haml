- content_for(:title) { "Semaine du #{l(@start_of_week, format: '%d %B')}" }

.space-y-6
  -# Navigation
  .flex.items-center.justify-between
    = link_to week_path(date: @prev_week), class: "rounded-lg bg-gray-900 px-3 py-2 text-sm text-gray-400 ring-1 ring-gray-800 hover:bg-gray-800" do
      ← Précédente
    %h1.text-lg.font-semibold.text-gray-100
      Semaine du #{l(@start_of_week, format: "%d")} au #{l(@end_of_week, format: "%d %B %Y")}
    = link_to week_path(date: @next_week), class: "rounded-lg bg-gray-900 px-3 py-2 text-sm text-gray-400 ring-1 ring-gray-800 hover:bg-gray-800" do
      Suivante →

  -# Summary table
  .rounded-lg.bg-gray-900.ring-1.ring-gray-800.overflow-hidden
    %table.w-full.text-sm
      %thead
        %tr.border-b.border-gray-800.text-left.text-xs.text-gray-500
          %th.px-5.py-3 Discipline
          %th.px-5.py-3 Séances
          %th.px-5.py-3 Distance
          %th.px-5.py-3 Durée
          %th.px-5.py-3 D+
      %tbody
        - summary_by_sport.each do |sport, data|
          %tr.border-b.border-gray-800
            %td.px-5.py-3.text-gray-100
              %span.mr-2= Activity.new(sport: sport).sport_icon
              = I18n.t("sports.#{sport}", default: sport.humanize)
            %td.px-5.py-3.text-gray-300= data[:count]
            %td.px-5.py-3.text-gray-300= "#{data[:distance_km]} km"
            %td.px-5.py-3.text-gray-300= format_duration(data[:duration_seconds])
            %td.px-5.py-3.text-gray-300= "#{data[:elevation]} m"
        - if summary_by_sport.size > 1
          %tr.border-t-2.border-gray-700.font-semibold
            %td.px-5.py-3.text-gray-100 Total
            %td.px-5.py-3.text-gray-100= week_totals[:count]
            %td.px-5.py-3.text-gray-100= "#{week_totals[:distance_km]} km"
            %td.px-5.py-3.text-gray-100= format_duration(week_totals[:duration_seconds])
            %td.px-5.py-3.text-gray-100= "#{week_totals[:elevation]} m"

  -# Day by day
  .space-y-3
    - (@start_of_week..@end_of_week).each do |day|
      - day_activities = @activities.select { |a| a.performed_at.to_date == day }
      - today = day == Date.current
      .rounded-lg.p-4{ class: today ? "bg-gray-800 ring-1 ring-indigo-500" : "bg-gray-900 ring-1 ring-gray-800" }
        .flex.items-center.justify-between.mb-2
          %h3.text-sm.font-medium{ class: today ? "text-indigo-400" : "text-gray-400" }
            = l(day, format: "%A %d %B").capitalize
          - if day_activities.any?
            %span.text-xs.text-gray-500= "#{day_activities.size} activité(s)"

        - if day_activities.any?
          .space-y-2
            - day_activities.each do |activity|
              = render "activities/activity_card", activity: activity
        - else
          %p.text-xs.text-gray-600.italic Repos
