- content_for(:title) { "Activités" }

.space-y-6
  .flex.items-center.justify-between
    %h1.text-2xl.font-bold.text-gray-100 Activités
    = link_to new_activity_path, class: "rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" do
      + Nouvelle activité

  - if @activities.any?
    .space-y-3
      - @activities.each do |activity|
        = render "activity_card", activity: activity

    - if @pagy.pages > 1
      .mt-6
        = pagy_dark_nav(@pagy)
  - else
    .rounded-lg.bg-gray-900.px-6.py-12.text-center.ring-1.ring-gray-800
      %p.text-gray-400 Aucune activité pour le moment.
      = link_to "Créer ta première activité", new_activity_path, class: "mt-4 inline-block text-sm font-medium text-indigo-400 hover:text-indigo-300"
