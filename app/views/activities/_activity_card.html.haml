= link_to activity_path(activity), class: "block rounded-lg bg-gray-900 p-5 ring-1 ring-gray-800 hover:ring-gray-700 transition" do
  .flex.items-center.justify-between
    .flex.items-center.gap-4
      %span.text-2xl= activity.sport_icon
      %div
        .flex.items-center.gap-2
          %h3.text-sm.font-semibold.text-gray-100= activity.title.presence || activity.sport.humanize
          - if activity.activity_tags.any?
            - activity.activity_tags.each do |tag|
              %span.inline-flex.items-center.rounded-full.px-2.py-0.5.text-xs.font-medium.text-gray-300{ style: "border-left: 3px solid #{tag.color}; background-color: #{tag.color}20" }
                = tag.name
        .mt-1.flex.items-center.gap-3.text-xs.text-gray-400
          %span= l(activity.performed_at, format: "%a %d %b %Y à %H:%M")
          - if activity.rpe
            %span.inline-flex.items-center.rounded-full.px-2.py-0.5.text-xs.font-medium.text-indigo-300.bg-indigo-950
              RPE #{activity.rpe}

    .flex.items-center.gap-6.text-sm.text-gray-300
      - if activity.distance_km
        %div
          %span.text-gray-500 Dist
          %br
          %span.font-medium= "#{activity.distance_km} km"
      - if activity.duration_formatted
        %div
          %span.text-gray-500 Durée
          %br
          %span.font-medium= activity.duration_formatted
      - if activity.pace_formatted
        %div
          %span.text-gray-500 Allure
          %br
          %span.font-medium= activity.pace_formatted
      - if activity.average_heart_rate
        %div
          %span.text-gray-500 FC
          %br
          %span.font-medium= "#{activity.average_heart_rate} bpm"
      - if activity.average_cadence
        %div
          %span.text-gray-500 Cad
          %br
          %span.font-medium= "#{activity.average_cadence} spm"
      - if activity.average_power
        %div
          %span.text-gray-500 Puiss
          %br
          %span.font-medium= "#{activity.average_power} W"
