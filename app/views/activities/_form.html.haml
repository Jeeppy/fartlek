= form_for(activity, html: { class: "space-y-6" }) do |f|
  = render "devise/shared/error_messages", resource: activity

  -# Sport + Titre
  .grid.grid-cols-2.gap-4
    %div
      = f.label :sport, "Sport", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.select :sport, Activity.sports.keys.map { |s| [I18n.t("sports.#{s}", default: s.humanize), s] }, {}, class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"
    %div
      = f.label :title, "Titre", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.text_field :title, placeholder: "Ex: Footing matinal", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm placeholder-gray-500 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

  -# Date + Durée
  .grid.grid-cols-2.gap-4
    %div
      = f.label :performed_at, "Date & heure", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.datetime_local_field :performed_at, class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"
    %div
      = f.label :duration_seconds, "Durée (secondes)", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.number_field :duration_seconds, min: 0, placeholder: "3600", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm placeholder-gray-500 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

  -# Distance + D+
  .grid.grid-cols-2.gap-4
    %div
      = f.label :distance_meters, "Distance (mètres)", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.number_field :distance_meters, min: 0, placeholder: "10000", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm placeholder-gray-500 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"
    %div
      = f.label :elevation_gain_meters, "Dénivelé+ (mètres)", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.number_field :elevation_gain_meters, min: 0, placeholder: "150", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm placeholder-gray-500 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

  -# FC moy + FC max
  .grid.grid-cols-2.gap-4
    %div
      = f.label :average_heart_rate, "FC moyenne", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.number_field :average_heart_rate, min: 30, max: 220, placeholder: "145", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm placeholder-gray-500 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"
    %div
      = f.label :max_heart_rate, "FC max", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.number_field :max_heart_rate, min: 30, max: 250, placeholder: "175", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm placeholder-gray-500 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

  -# Cadence + Puissance
  .grid.grid-cols-2.gap-4
    %div
      = f.label :average_cadence, "Cadence (spm)", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.number_field :average_cadence, min: 0, placeholder: "180", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm placeholder-gray-500 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"
    %div
      = f.label :average_power, "Puissance (W)", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.number_field :average_power, min: 0, placeholder: "250", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm placeholder-gray-500 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

  -# Allure + Calories
  .grid.grid-cols-2.gap-4
    %div
      = f.label :average_pace_seconds_per_km, "Allure (sec/km)", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.number_field :average_pace_seconds_per_km, min: 0, placeholder: "330", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm placeholder-gray-500 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"
    %div
      = f.label :calories, "Calories", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.number_field :calories, min: 0, placeholder: "650", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm placeholder-gray-500 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

  -# RPE + Ressenti
  .grid.grid-cols-2.gap-4
    %div{ data: { controller: "rpe-slider" } }
      = f.label :rpe, "RPE (effort perçu)", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.range_field :rpe, min: 1, max: 10, step: 1, value: activity.rpe || 5, class: "w-full accent-indigo-500", data: { action: "input->rpe-slider#update", rpe_slider_target: "slider" }
      .mt-1.text-center.text-sm.font-semibold.text-indigo-400{ data: { rpe_slider_target: "value" } }
        = activity.rpe || 5
    %div
      = f.label :feeling, "Ressenti", class: "block text-sm font-medium text-gray-300 mb-1"
      = f.select :feeling, Activity.feelings.keys.map { |fe| [I18n.t("feelings.#{fe}", default: fe.humanize), fe] }, { include_blank: "—" }, class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

  -# Équipement
  %div
    = f.label :equipment_id, "Équipement", class: "block text-sm font-medium text-gray-300 mb-1"
    = f.select :equipment_id, current_user.equipments.active.ordered.map { |e| [e.name, e.id] }, { include_blank: "— Aucun —" }, class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

  -# Notes
  %div
    = f.label :notes, "Notes", class: "block text-sm font-medium text-gray-300 mb-1"
    = f.text_area :notes, rows: 3, placeholder: "Sensations, météo, parcours...", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm placeholder-gray-500 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

  -# Submit
  .flex.items-center.gap-4
    = f.submit (activity.persisted? ? "Mettre à jour" : "Créer l'activité"), class: "rounded-lg bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer focus:outline-none focus:ring-2 focus:ring-indigo-500/50"
    = link_to "Annuler", (activity.persisted? ? activity_path(activity) : activities_path), class: "text-sm text-gray-400 hover:text-gray-300"
