- flash.each do |type, message|
  - color = case type.to_sym
  - when :notice, :success then "green"
  - when :alert, :error then "red"
  - else; "blue"
  .mb-4.rounded-md.p-4{ class: "bg-#{color}-900/50 border border-#{color}-800", data: { controller: "flash", flash_delay_value: "5000" } }
    .flex.items-center.justify-between
      %p.text-sm.font-medium{ class: "text-#{color}-300" }= message
      %button.ml-3{ type: "button", class: "text-#{color}-400 hover:text-#{color}-200", data: { action: "click->flash#dismiss" } }
        %svg.h-5.w-5{ viewBox: "0 0 20 20", fill: "currentColor" }
          %path{ "fill-rule": "evenodd", d: "M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z", "clip-rule": "evenodd" }
