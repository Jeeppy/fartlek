%nav.border-b.border-gray-800.bg-gray-900
  .mx-auto.max-w-7xl.px-4{ class: "sm:px-6 lg:px-8" }
    .flex.h-16.justify-between
      .flex
        = link_to root_path, class: "flex shrink-0 items-center" do
          %span.text-xl.font-bold.text-indigo-400 Fartlek

        .hidden{ class: "sm:ml-8 sm:flex sm:space-x-4" }
          = nav_link "Dashboard", authenticated_root_path

      .flex.items-center
        .relative{ data: { controller: "dropdown" } }
          %button.flex.items-center.gap-2.rounded-md.px-3.py-2.text-sm.font-medium.text-gray-300{ type: "button", class: "hover:bg-gray-800", data: { action: "click->dropdown#toggle", dropdown_target: "button" } }
            %span= current_user.first_name
            %svg.h-4.w-4{ fill: "none", viewBox: "0 0 24 24", "stroke-width": "1.5", stroke: "currentColor" }
              %path{ "stroke-linecap": "round", "stroke-linejoin": "round", d: "M19.5 8.25l-7.5 7.5-7.5-7.5" }

          .absolute.right-0.z-10.mt-2.w-48.origin-top-right.rounded-md.bg-gray-800.py-1.shadow-lg.hidden{ class: "ring-1 ring-gray-700", data: { dropdown_target: "menu" } }
            = link_to "Profil", edit_user_registration_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700"
            = button_to "Déconnexion", destroy_user_session_path, method: :delete, class: "block w-full px-4 py-2 text-left text-sm text-gray-300 hover:bg-gray-700"
