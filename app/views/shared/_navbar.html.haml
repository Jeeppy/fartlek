%nav.bg-gray-950.border-b.border-gray-800.sticky.top-0.z-30
  .mx-auto.max-w-7xl.px-4
    .flex.items-center.justify-between.h-14

      -# Logo + Nav principale
      .flex.items-center.gap-6
        = link_to root_path, class: "text-lg font-bold text-indigo-400 hover:text-indigo-300" do
          Fartlek

        .flex.items-center.gap-1
          = nav_link "Planning", week_path(date: Date.current.beginning_of_week)
          = nav_link "Calendrier", month_calendar_path(Date.current.year, Date.current.month)
          = nav_link "Activités", activities_path
          = nav_link "Compétitions", competitions_path

      -# Actions rapides + User menu
      .flex.items-center.gap-3

        -# Notifications
        - notifs = notifications
        %div{ data: { controller: "dropdown" } }
          %button.relative.flex.items-center.justify-center.h-8.w-8.rounded-lg.text-gray-400{ type: "button", data: { action: "click->dropdown#toggle", dropdown_target: "button" }, class: "hover:bg-gray-800" }
            %svg.h-5.w-5{ fill: "none", viewBox: "0 0 24 24", "stroke-width": "1.5", stroke: "currentColor" }
              %path{ "stroke-linecap": "round", "stroke-linejoin": "round", d: "M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" }
            - if notifs.any?
              %span.absolute.top-0.right-0.h-2.w-2.rounded-full.bg-indigo-500

          .relative{ data: { dropdown_target: "menu" }, class: "hidden" }
            .absolute.right-0.mt-2.w-80.rounded-lg.bg-gray-900.shadow-lg.ring-1.ring-gray-800.z-50
              .px-4.py-3.border-b.border-gray-800.flex.items-center.justify-between
                %span.text-sm.font-medium.text-gray-100 Notifications
                - if notifs.any?
                  %span.text-xs.text-gray-500= "#{notifs.count} nouvelle(s)"
              - if notifs.any?
                .py-2.max-h-96.overflow-y-auto
                  - notifs.each do |notif|
                    = link_to notif[:link], class: "flex items-start gap-3 px-4 py-3 hover:bg-gray-800 transition" do
                      %span.text-lg.shrink-0= notif[:icon]
                      %div.min-w-0
                        %p.text-sm.font-medium.text-gray-100.truncate= notif[:title]
                        %p.text-xs.text-gray-400.truncate= notif[:body]
                      - dot_color = { warning: "bg-orange-400", success: "bg-green-400", info: "bg-blue-400" }[notif[:type]]
                      %span.h-2.w-2.rounded-full.shrink-0.mt-1.5{ class: dot_color }
              - else
                .px-4.py-8.text-center
                  %p.text-sm.text-gray-500 Aucune notification

        -# Bouton +
        %div{ data: { controller: "dropdown" } }
          %button.flex.items-center.justify-center.h-8.w-8.rounded-lg.bg-indigo-600.text-white.text-lg.font-bold{ type: "button", data: { action: "click->dropdown#toggle", dropdown_target: "button" }, class: "hover:bg-indigo-500" }
            +
          .relative{ data: { dropdown_target: "menu" }, class: "hidden" }
            .absolute.right-0.mt-2.w-56.rounded-lg.bg-gray-900.shadow-lg.ring-1.ring-gray-800.py-2.z-50
              = link_to new_planned_session_path(date: Date.current), class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700" do
                Planifier une séance
              = link_to new_activity_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700" do
                Ajouter une activité
              = link_to new_daily_journal_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700" do
                Journal du jour
              = link_to new_competition_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700" do
                Compétition

        -# User menu
        %div{ data: { controller: "dropdown" } }
          %button.flex.items-center.gap-2.rounded-lg.px-3.py-1.5.text-sm.text-gray-300{ type: "button", data: { action: "click->dropdown#toggle", dropdown_target: "button" }, class: "hover:bg-gray-800" }
            .flex.items-center.justify-center.h-7.w-7.rounded-full.bg-gray-700.text-xs.font-semibold.text-gray-300
              = current_user.first_name[0..1].upcase
            %span= current_user.first_name
            %svg.h-4.w-4.text-gray-500{ fill: "none", viewBox: "0 0 24 24", "stroke-width": "1.5", stroke: "currentColor" }
              %path{ "stroke-linecap": "round", "stroke-linejoin": "round", d: "M19.5 8.25l-7.5 7.5-7.5-7.5" }

          .relative{ data: { dropdown_target: "menu" }, class: "hidden" }
            .absolute.right-0.mt-2.w-56.rounded-lg.bg-gray-900.shadow-lg.ring-1.ring-gray-800.py-2.z-50
              -# Profil
              .px-4.py-2.border-b.border-gray-800
                %p.text-sm.font-medium.text-gray-100= current_user.full_name
                %p.text-xs.text-gray-500= current_user.email

              = link_to "Profil", edit_user_registration_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700"
              = link_to "Zones FC", settings_heart_rate_zones_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700"
              = link_to "Zones allure", settings_pace_zones_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700"

              -# Outils
              .border-t.border-gray-800.mt-1.pt-1
                = link_to "Métriques", user_metrics_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700"
                = link_to "Journal", daily_journals_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700"
                = link_to "Équipement", equipment_index_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700"
                = link_to "Phases", training_phases_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700"
                = link_to "Tags séance", activity_tags_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700"

              -# Intégrations
              .border-t.border-gray-800.mt-1.pt-1
                = link_to settings_strava_path, class: "flex items-center justify-between px-4 py-2 text-sm text-gray-300 hover:bg-gray-700" do
                  %span Strava
                  - if current_user.strava_credential
                    - if current_user.strava_credential.last_sync_at
                      %span.text-xs.text-gray-500= "Sync #{time_ago_in_words(current_user.strava_credential.last_sync_at)}"
                    - else
                      %span.h-2.w-2.rounded-full.bg-green-400{ title: "Connecté" }
                  - else
                    %span.text-xs.text-gray-500 Non connecté
                = link_to "AI Coach", ai_planning_path, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-gray-700"

              -# Déconnexion
              .border-t.border-gray-800.mt-1.pt-1
                = button_to "Déconnexion", destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-red-400 hover:bg-gray-700 cursor-pointer"
