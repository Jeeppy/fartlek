.mt-6.text-center.text-sm.text-gray-500.space-y-1
  - if controller_name != "sessions"
    %p= link_to "Déjà un compte ? Se connecter", new_session_path(resource_name), class: "font-medium text-indigo-400 hover:text-indigo-300"

  - if devise_mapping.registerable? && controller_name != "registrations"
    %p= link_to "Créer un compte", new_registration_path(resource_name), class: "font-medium text-indigo-400 hover:text-indigo-300"

  - if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations"
    %p= link_to "Mot de passe oublié ?", new_password_path(resource_name), class: "font-medium text-indigo-400 hover:text-indigo-300"
