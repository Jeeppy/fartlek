.w-full.max-w-md
  .text-center.mb-8
    %h1.text-3xl.font-bold.text-indigo-400 Fartlek
    %p.mt-2.text-sm.text-gray-400 Connecte-toi à ton carnet d'entraînement

  .rounded-lg.bg-gray-900.px-8.py-10.shadow-lg.ring-1.ring-gray-800
    = render "devise/shared/error_messages", resource: resource

    = form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f|
      %div
        = f.label :email, class: "block text-sm font-medium text-gray-300 mb-1"
        = f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "ton@email.com", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm placeholder-gray-500 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

      %div
        = f.label :password, "Mot de passe", class: "block text-sm font-medium text-gray-300 mb-1"
        = f.password_field :password, autocomplete: "current-password", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

      - if devise_mapping.rememberable?
        .flex.items-center.justify-between
          %label.flex.items-center
            = f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-600 bg-gray-800 text-indigo-500 focus:ring-indigo-500 focus:ring-offset-0 focus:outline-none"
            %span.ml-2.text-sm.text-gray-400 Se souvenir de moi

      %div
        = f.submit "Se connecter", class: "flex w-full justify-center rounded-lg bg-indigo-600 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer focus:outline-none focus:ring-2 focus:ring-indigo-500/50"

    = render "devise/shared/links"
