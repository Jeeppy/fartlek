.w-full.max-w-md
  .text-center.mb-8
    %h1.text-3xl.font-bold.text-indigo-400 Fartlek
    %p.mt-2.text-sm.text-gray-400 Crée ton compte pour suivre tes entraînements

  .rounded-lg.bg-gray-900.px-8.py-10.shadow-lg.ring-1.ring-gray-800
    = render "devise/shared/error_messages", resource: resource

    = form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f|
      .grid.grid-cols-2.gap-4
        %div
          = f.label :first_name, "Prénom", class: "block text-sm font-medium text-gray-300 mb-1"
          = f.text_field :first_name, autofocus: true, autocomplete: "given-name", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"
        %div
          = f.label :last_name, "Nom", class: "block text-sm font-medium text-gray-300 mb-1"
          = f.text_field :last_name, autocomplete: "family-name", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

      %div
        = f.label :email, class: "block text-sm font-medium text-gray-300 mb-1"
        = f.email_field :email, autocomplete: "email", placeholder: "ton@email.com", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm placeholder-gray-500 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

      .grid.grid-cols-2.gap-4
        %div
          = f.label :gender, "Genre", class: "block text-sm font-medium text-gray-300 mb-1"
          = f.select :gender, options_for_select([["Homme", "male"], ["Femme", "female"], ["Autre", "other"]], resource.gender), { prompt: "Choisir" }, class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"
        %div
          = f.label :date_of_birth, "Date de naissance", class: "block text-sm font-medium text-gray-300 mb-1"
          = f.date_field :date_of_birth, max: Date.current, class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

      %div
        = f.label :password, "Mot de passe", class: "block text-sm font-medium text-gray-300 mb-1"
        = f.password_field :password, autocomplete: "new-password", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"
        %p.mt-1.text-xs.text-gray-500= "#{@minimum_password_length} caractères minimum"

      %div
        = f.label :password_confirmation, "Confirmer le mot de passe", class: "block text-sm font-medium text-gray-300 mb-1"
        = f.password_field :password_confirmation, autocomplete: "new-password", class: "block w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-3 text-gray-100 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/50 focus:outline-none"

      %div
        = f.submit "Créer mon compte", class: "flex w-full justify-center rounded-lg bg-indigo-600 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer focus:outline-none focus:ring-2 focus:ring-indigo-500/50"

    = render "devise/shared/links"
