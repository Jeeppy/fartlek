- content_for(:title) { @equipment.name }

.space-y-6
  .flex.items-center.justify-between
    .flex.items-center.gap-4
      %span.text-3xl= @equipment.shoes? ? "👟" : @equipment.bike? ? "🚲" : "🔧"
      %div
        %h1.text-2xl.font-bold.text-gray-100= @equipment.name
        %p.text-sm.text-gray-400= [@equipment.brand, @equipment.model].compact.join(" ")
        - if @equipment.purchase_date
          %p.text-xs.text-gray-500= "Depuis #{l(@equipment.purchase_date, format: '%B %Y')}"
    .flex.items-center.gap-3
      = link_to "Modifier", edit_equipment_path(@equipment), class: "rounded-lg bg-gray-800 px-4 py-2.5 text-sm font-medium text-gray-300 ring-1 ring-gray-700 hover:bg-gray-700"

  -# Usure
  .rounded-lg.bg-gray-900.p-6.ring-1.ring-gray-800
    %h2.text-xs.font-medium.text-gray-500.uppercase.tracking-wider.mb-4 Usure
    .grid.grid-cols-3.gap-6
      %div
        %dt.text-xs.text-gray-500 Distance totale
        %dd.mt-1.text-xl.font-bold.text-gray-100= "#{@equipment.total_distance_km} km"
      - if @equipment.max_distance_meters&.positive?
        %div
          %dt.text-xs.text-gray-500 Durée de vie
          %dd.mt-1.text-xl.font-bold.text-gray-100= "#{(@equipment.max_distance_meters / 1000.0).round(0)} km"
        %div
          %dt.text-xs.text-gray-500 Restant
          %dd.mt-1.text-xl.font-bold{ class: @equipment.needs_replacement? ? "text-red-400" : "text-gray-100" }
            = "#{@equipment.usage_percent}%"
    - if @equipment.usage_percent
      .mt-4
        .h-3.w-full.rounded-full.bg-gray-800
          - color = @equipment.needs_replacement? ? "bg-red-500" : @equipment.usage_percent > 75 ? "bg-orange-500" : "bg-green-500"
          .h-3.rounded-full{ class: color, style: "width: #{[@equipment.usage_percent, 100].min}%" }

  -# Activités avec cet équipement
  - activities = @equipment.activities.chronological.limit(10)
  - if activities.any?
    .rounded-lg.bg-gray-900.ring-1.ring-gray-800.overflow-hidden
      .px-5.py-4.border-b.border-gray-800
        .flex.items-center.justify-between
          %h2.text-xs.font-medium.text-gray-500.uppercase.tracking-wider Dernières activités
          %span.text-xs.text-gray-500= "#{@equipment.activities.count} au total"
      %table.w-full.text-sm
        %tbody
          - activities.each_with_index do |activity, i|
            %tr{ class: "border-b border-gray-800 #{i.even? ? '' : 'bg-gray-800/30'}" }
              %td.px-5.py-3
                = link_to activity_path(activity), class: "flex items-center gap-2 hover:text-indigo-300 transition" do
                  %span= activity.sport_icon
                  %span.text-gray-100= activity.title.presence || activity.sport.humanize
              %td.px-5.py-3.text-gray-400.text-xs= l(activity.performed_at, format: "%d/%m/%Y")
              %td.px-5.py-3.text-gray-400.text-xs= activity.distance_km ? "#{activity.distance_km} km" : activity.duration_formatted

  -# Notes
  - if @equipment.notes.present?
    .rounded-lg.bg-gray-900.p-5.ring-1.ring-gray-800
      %h2.text-xs.font-medium.text-gray-500.uppercase.tracking-wider.mb-3 Notes
      %p.text-sm.text-gray-300= @equipment.notes

  = link_to "← Retour", equipment_index_path, class: "inline-block text-sm text-gray-400 hover:text-gray-300"
