- content_for(:title) { "Tags de séance" }

.space-y-6
  .flex.items-center.justify-between
    %h1.text-2xl.font-bold.text-gray-100 Tags de séance
    = button_to "Générer les tags par défaut", generate_activity_tags_path, method: :post, class: "rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-500 cursor-pointer"

  - if @tags.any?
    .flex.flex-wrap.gap-3
      - @tags.each do |tag|
        %span.inline-flex.items-center.rounded-full.px-4.py-2.text-sm.font-medium.text-gray-100.bg-gray-900.ring-1.ring-gray-800{ style: "border-left: 4px solid #{tag.color}" }
          = tag.name
  - else
    .rounded-lg.bg-gray-900.px-6.py-12.text-center.ring-1.ring-gray-800
      %p.text-gray-400 Aucun tag défini.
      %p.text-sm.text-gray-500.mt-2 Clique sur "Générer les tags par défaut" pour commencer.
