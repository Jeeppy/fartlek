- content_for(:title) { "Bilan hebdomadaire" }

.space-y-6
  .flex.items-center.justify-between
    %h1.text-2xl.font-bold.text-gray-100 Bilan hebdomadaire
    = link_to new_weekly_journal_path, class: "rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-500" do
      + Cette semaine

  - if @journals.any?
    .space-y-2
      - @journals.each do |journal|
        = link_to weekly_journal_path(week: journal.week_start_date), class: "block rounded-lg bg-gray-900 p-4 ring-1 ring-gray-800 hover:ring-gray-700 transition" do
          .flex.items-center.justify-between
            %div
              %h3.text-sm.font-medium.text-gray-100
                Semaine du #{l(journal.week_start_date, format: "%d %B %Y")}
              .flex.items-center.gap-4.mt-1.text-xs.text-gray-400
                %span Plaisir #{journal.pleasure}/5
                %span Difficulté #{journal.difficulty}/5
                %span Fatigue #{journal.fatigue}/5
            - if journal.comment.present?
              %span.text-xs.text-gray-500 💬

    - if @pagy.pages > 1
      .mt-6
        = pagy_dark_nav(@pagy)
  - else
    .rounded-lg.bg-gray-900.px-6.py-12.text-center.ring-1.ring-gray-800
      %p.text-gray-400 Aucun bilan enregistré.
