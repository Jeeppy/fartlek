- content_for(:title) { "Bilan semaine" }

.space-y-6
  .flex.items-center.justify-between
    %h1.text-2xl.font-bold.text-gray-100 Bilan semaine du #{l(@journal.week_start_date, format: "%d %B %Y")}
    = link_to "Modifier", edit_weekly_journal_path(week: @journal.week_start_date), class: "rounded-lg bg-gray-800 px-4 py-2 text-sm font-medium text-gray-300 ring-1 ring-gray-700 hover:bg-gray-700"

  .grid.grid-cols-3.gap-4
    .rounded-lg.bg-gray-900.px-4.py-4.ring-1.ring-gray-800
      %dt.text-xs.font-medium.text-gray-500 Plaisir
      %dd.mt-1.text-lg.font-semibold.text-gray-100= @journal.pleasure ? "#{@journal.pleasure}/5" : "—"
    .rounded-lg.bg-gray-900.px-4.py-4.ring-1.ring-gray-800
      %dt.text-xs.font-medium.text-gray-500 Difficulté
      %dd.mt-1.text-lg.font-semibold.text-gray-100= @journal.difficulty ? "#{@journal.difficulty}/5" : "—"
    .rounded-lg.bg-gray-900.px-4.py-4.ring-1.ring-gray-800
      %dt.text-xs.font-medium.text-gray-500 Fatigue
      %dd.mt-1.text-lg.font-semibold.text-gray-100= @journal.fatigue ? "#{@journal.fatigue}/5" : "—"

  - if @journal.comment.present?
    .rounded-lg.bg-gray-900.p-5.ring-1.ring-gray-800
      %h2.text-sm.font-medium.text-gray-400.mb-2 Commentaire
      %p.text-sm.text-gray-300.whitespace-pre-wrap= @journal.comment

  = link_to "← Retour", weekly_journals_path, class: "inline-block text-sm text-gray-400 hover:text-gray-300"
