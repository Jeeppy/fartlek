- content_for(:title) { "Strava" }

.space-y-6
  %h1.text-2xl.font-bold.text-gray-100 Strava

  - if @credential
    .rounded-lg.bg-gray-900.p-5.ring-1.ring-gray-800
      .flex.items-center.justify-between
        %div
          %span.text-sm.font-medium.text-green-400 Connecté
          - if @credential.last_sync_at
            %p.text-xs.text-gray-500.mt-1
              Dernière sync : #{l(@credential.last_sync_at, format: :short)}
        .flex.items-center.gap-3
          = button_to "Synchroniser", sync_settings_strava_path, method: :post, class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 cursor-pointer"
          = button_to "Déconnecter", settings_strava_path, method: :delete, data: { turbo_confirm: "Déconnecter Strava ?" }, class: "rounded-lg bg-red-900 px-4 py-2 text-sm font-medium text-red-300 hover:bg-red-800 cursor-pointer"
  - else
    .rounded-lg.bg-gray-900.px-6.py-12.text-center.ring-1.ring-gray-800
      %p.text-gray-400.mb-4 Connecte ton compte Strava pour synchroniser tes activités.
      = link_to "Connecter Strava", @authorize_url, class: "rounded-lg bg-orange-600 px-6 py-3 text-sm font-semibold text-white hover:bg-orange-500"
